{
  "entryPoints": [
    "src/index.d.ts",
    "src/chronicle.d.ts",
    "src/diff.d.ts",
    "src/causal.d.ts",
    "src/query.d.ts",
    "src/trace.d.ts",
    "src/time-travel.d.ts",
    "src/persistent.d.ts",
    "src/semantic.d.ts",
    "src/praxis.d.ts",
    "src/rules/index.d.ts"
  ],
  "entryPointStrategy": "resolve",
  "out": "docs/typedoc",
  "name": "@plures/chronos",
  "readme": "README.md",
