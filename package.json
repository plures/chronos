{
  "name": "@plures/chronos",
  "version": "0.1.0",
  "description": "Graph-native application state chronicle — zero-effort observability through PluresDB state diffs",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./chronicle": {
      "types": "./src/chronicle.d.ts",
      "import": "./src/chronicle.js"
    },
    "./diff": {
      "types": "./src/diff.d.ts",
      "import": "./src/diff.js"
    },
    "./trace": {
      "types": "./src/trace.d.ts",
      "import": "./src/trace.js"
    },
    "./query": {
      "types": "./src/query.d.ts",
      "import": "./src/query.js"
    },
    "./causal": {
      "types": "./src/causal.d.ts",
      "import": "./src/causal.js"
    },
    "./praxis": {
      "types": "./src/praxis.d.ts",
      "import": "./src/praxis.js"
    },
    "./rules": {
      "types": "./src/rules/index.d.ts",
      "import": "./src/rules/index.js"
    },
    "./time-travel": {
      "types": "./src/time-travel.d.ts",
      "import": "./src/time-travel.js"
    }
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/plures/chronos.git"
  },
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@plures/praxis": "^1.4.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "svelte": "^5.54.0",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  },
  "browser": {
    "node:async_hooks": false
  }
}
