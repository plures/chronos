{
  "name": "@plures/chronos",
  "version": "0.5.0",
  "description": "Graph-native application state chronicle — zero-effort observability through PluresDB state diffs",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./chronicle": {
      "types": "./src/chronicle.d.ts",
      "import": "./src/chronicle.js"
    },
    "./diff": {
      "types": "./src/diff.d.ts",
      "import": "./src/diff.js"
    },
    "./trace": {
      "types": "./src/trace.d.ts",
      "import": "./src/trace.js"
    },
    "./query": {
      "types": "./src/query.d.ts",
      "import": "./src/query.js"
    },
    "./causal": {
      "types": "./src/causal.d.ts",
      "import": "./src/causal.js"
    },
    "./praxis": {
      "types": "./src/praxis.d.ts",
      "import": "./src/praxis.js"
    },
    "./rules": {
      "types": "./src/rules/index.d.ts",
      "import": "./src/rules/index.js"
    },
    "./time-travel": {
      "types": "./src/time-travel.d.ts",
      "import": "./src/time-travel.js"
    },
    "./persistent": {
      "types": "./src/persistent.d.ts",
      "import": "./src/persistent.js"
    },
    "./semantic": {
      "types": "./src/semantic.d.ts",
      "import": "./src/semantic.js"
    }
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "docs:build": "jsdoc -c jsdoc.json",
    "docs:typedoc": "typedoc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/plures/chronos.git"
  },
  "files": [
    "src/**/*.js",
    "src/**/*.d.ts",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "BSL-1.1",
  "dependencies": {
    "@plures/praxis": "^2.4.33"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "jsdoc": "^4.0.5",
    "svelte": "^5.55.0",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "browser": {
    "node:async_hooks": false
  },
  "engines": {
    "node": ">=24"
  }
}
