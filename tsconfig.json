{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "strict": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "noEmit": true,
    "skipLibCheck": true,
    "declaration": false,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.js", "src/**/*.d.ts"]
}
